{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "data": {
    "url": "https://raw.githubusercontent.com/brandonmonash/FIT2179-A2/main/Data/Mean%20Temperature%20Anomaly.csv"
  },
  "mark": "rect",
  "width": 800,
  "height": 80,
  "encoding": {
    "x": {
      "field": "Year",
      "type": "ordinal",
      "title": "Year",
      "axis": {
        "labelOverlap": true,
        "labelAngle": 0
      }
    },
    "color": {
      "field": "Anomaly",
      "type": "quantitative",
      "scale": {
        "scheme": "redblue",
        "reverse": true,
        "domainMid": 0
      },
      "title": "Temperature Anomaly (°C)"
    },
    "tooltip": [
      {"field": "Year", "type": "ordinal"},
      {"field": "Anomaly", "type": "quantitative", "format": ".2f"}
    ]
  }
}