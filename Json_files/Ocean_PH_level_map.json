{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "title": "Surface Water pH Change 1982-2022",
  "width": 800,
  "height": 500,
  "projection": {
    "type": "mercator",
    "center": [134, -25],
    "scale": 700
  },
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/brandonmonash/FIT2179-A2/main/Data/OA1%20-%20Surface%20water%20pH%20change%201982-2022.csv"
      },
      "transform": [
        {"filter": "datum.ph_total != null && datum.ph_total != ''"}
      ],
      "mark": {"type": "rect", "width": 12, "height": 12},
      "encoding": {
        "longitude": {"field": "lon", "type": "quantitative"},
        "latitude": {"field": "lat", "type": "quantitative"},
        "color": {
          "field": "ph_total",
          "type": "quantitative",
          "scale": {
            "domain": [-0.09, -0.06],
            "clamp": true,
            "range": ["#d73027", "#fc8d59", "#fee090", "#e0f3f8", "#4575b4"]
          },
          "title": "pH Change"
        },
        "tooltip": [
          {"field": "ph_total", "title": "pH Change", "format": ".3f"},
          {"field": "lat", "title": "Latitude"},
          {"field": "lon", "title": "Longitude"}
        ]
      }
    },
    {
      "data": {
        "url": "https://vega.github.io/vega-datasets/data/world-110m.json",
        "format": {"type": "topojson", "feature": "countries"}
      },
      "mark": {"type": "geoshape", "fill": null, "stroke": "white", "strokeWidth": 0.5}
    }
  ]
}